---
- name: Audit simple d'un poste Windows
  hosts: windows
  gather_facts: no

  tasks:
    - name: Tester la communication avec le poste
      ansible.windows.win_ping:

    - name: Creer le dossier de rapport
      ansible.windows.win_file:
        path: C:\Temp\ansible
        state: directory

    - name: Recuperer les informations du poste
      ansible.windows.win_shell: |
        $date = Get-Date -Format "dd/MM/yyyy HH:mm:ss"
        $hostname = hostname
        $user = whoami
        $windows = (Get-CimInstance Win32_OperatingSystem).Caption
        $version = (Get-CimInstance Win32_OperatingSystem).Version
        $ram = [math]::Round((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory / 1GB, 2)
        $ip = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object {$_.IPAddress -notlike "169.*" -and $_.IPAddress -ne "127.0.0.1"} | Select-Object -First 1).IPAddress
        $disk = Get-CimInstance Win32_LogicalDisk -Filter "DeviceID='C:'"
        $diskTotal = [math]::Round($disk.Size / 1GB, 2)
        $diskFree = [math]::Round($disk.FreeSpace / 1GB, 2)

        @"
        RAPPORT D'AUDIT WINDOWS

        Date du test : $date
        Nom du poste : $hostname
        Utilisateur : $user
        Adresse IP : $ip

        Systeme : $windows
        Version : $version

        Memoire RAM : $ram Go

        Disque C:
        - Taille totale : $diskTotal Go
        - Espace libre : $diskFree Go

        Test realise automatiquement avec Ansible.
        Projet : Modernisation reseau CIEL
        "@
      register: audit_result

    - name: Enregistrer le rapport sur le poste Windows
      ansible.windows.win_copy:
        content: "{{ audit_result.stdout }}"
        dest: C:\Temp\ansible\rapport_audit.txt

    - name: Afficher le rapport dans le terminal Ansible
      ansible.builtin.debug:
        var: audit_result.stdout_lines
